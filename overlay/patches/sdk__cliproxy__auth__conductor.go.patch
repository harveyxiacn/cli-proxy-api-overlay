+func (m *Manager) beginAuthRefresh(ctx context.Context, id string) (*authRefreshFlight, bool) {
+	if m == nil || id == "" {
+		return nil, false
+	}
+	m.mu.Lock()
+	if m.refreshFlights == nil {
+		m.refreshFlights = make(map[string]*authRefreshFlight)
+	}
+	if existing := m.refreshFlights[id]; existing != nil {
+		done := existing.done
+		m.mu.Unlock()
+		select {
+		case <-done:
+		case <-ctx.Done():
+		}
+		return nil, false
+	}
+	flight := &authRefreshFlight{done: make(chan struct{})}
+	m.refreshFlights[id] = flight
+	m.mu.Unlock()
+	return flight, true
+}
+
+func (m *Manager) endAuthRefresh(id string, flight *authRefreshFlight) {
+	if m == nil || id == "" || flight == nil {
+		return
+	}
+	m.mu.Lock()
+	if current := m.refreshFlights[id]; current == flight {
+		delete(m.refreshFlights, id)
+		close(flight.done)
+	}
+	m.mu.Unlock()
+}
+
+func authRefreshTokenValue(auth *Auth) string {
+	if auth == nil || auth.Metadata == nil {
+		return ""
+	}
+	value, _ := auth.Metadata["refresh_token"].(string)
+	return strings.TrimSpace(value)
+}
+
+func refreshRaceRecoveredByNewToken(err error, previous *Auth, current *Auth) bool {
+	if err == nil {
+		return false
+	}
+	raw := strings.ToLower(err.Error())
+	if !strings.Contains(raw, "refresh_token_reused") &&
+		!strings.Contains(raw, "invalid_grant") &&
+		!strings.Contains(raw, "invalid grant") {
+		return false
+	}
+	previousToken := authRefreshTokenValue(previous)
+	currentToken := authRefreshTokenValue(current)
+	return previousToken != "" && currentToken != "" && previousToken != currentToken
+}
