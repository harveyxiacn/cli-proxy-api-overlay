+// RefreshAuthByID explicitly refreshes a single auth credential by ID.
+// It blocks until the refresh attempt completes and respects any in-flight
+// singleflight deduplication that may be active for this auth.
+// This is the public entry point used by overlay code (e.g. TriggerRefreshAllThrottled)
+// so that overlay files only call exported methods and remain version-independent.
+func (m *Manager) RefreshAuthByID(ctx context.Context, id string) {
+	if m == nil || id == "" {
+		return
+	}
+	m.refreshAuth(ctx, id)
+}
