+// DisableCooling
+func (h *Handler) GetDisableCooling(c *gin.Context) {
+	c.JSON(200, gin.H{"disable-cooling": h.cfg.DisableCooling})
+}
+func (h *Handler) PutDisableCooling(c *gin.Context) {
+	h.updateBoolField(c, func(v bool) { h.cfg.DisableCooling = v })
+}
+
+// AuthAutoRefreshWorkers
+func (h *Handler) GetAuthAutoRefreshWorkers(c *gin.Context) {
+	c.JSON(200, gin.H{"auth-auto-refresh-workers": h.cfg.AuthAutoRefreshWorkers})
+}
+func (h *Handler) PutAuthAutoRefreshWorkers(c *gin.Context) {
+	var body struct {
+		Value *int `json:"value"`
+	}
+	if errBindJSON := c.ShouldBindJSON(&body); errBindJSON != nil || body.Value == nil {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid body"})
+		return
+	}
+	value := *body.Value
+	if value < 0 {
+		value = 0
+	}
+	h.cfg.AuthAutoRefreshWorkers = value
+	h.persist(c)
+}
