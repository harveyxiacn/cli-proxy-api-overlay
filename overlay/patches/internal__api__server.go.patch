+func (s *Server) serveExtendedPanel(c *gin.Context) {
+	// Resolve extended.html relative to the config file (same directory as config.yaml).
+	configDir := filepath.Dir(s.configFilePath)
+	filePath := filepath.Join(configDir, "extended.html")
+	if _, err := os.Stat(filePath); err != nil {
+		c.AbortWithStatus(http.StatusNotFound)
+		return
+	}
+	// Prevent browser caching so that edits to extended.html take effect on next refresh.
+	c.Header("Cache-Control", "no-cache, no-store, must-revalidate")
+	c.Header("Pragma", "no-cache")
+	c.Header("Expires", "0")
+	c.File(filePath)
+}
