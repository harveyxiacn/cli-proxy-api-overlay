+// PostAuthFilesFieldsBatch updates organization fields for multiple auth files.
+func (h *Handler) PostAuthFilesFieldsBatch(c *gin.Context) {
+	if h.authManager == nil {
+		c.JSON(http.StatusServiceUnavailable, gin.H{"error": "core auth manager unavailable"})
+		return
+	}
+	var req struct {
+		Names      []string              `json:"names"`
+		Set        authFileFieldBatchSet `json:"set"`
+		AddTags    []string              `json:"add_tags"`
+		RemoveTags []string              `json:"remove_tags"`
+	}
+	if err := c.ShouldBindJSON(&req); err != nil {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid request body"})
+		return
+	}
+	names := uniqueAuthFileNames(req.Names)
+	if len(names) == 0 {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "names is required"})
+		return
+	}
+	addTags := normalizeTags(req.AddTags)
+	removeTags := normalizeTags(req.RemoveTags)
+	removeSet := make(map[string]struct{}, len(removeTags))
+	for _, tag := range removeTags {
+		removeSet[strings.ToLower(tag)] = struct{}{}
+	}
+
+	updatedFiles := make([]string, 0, len(names))
+	failed := make([]gin.H, 0)
+	for _, name := range names {
+		auth := h.findAuthByName(name)
+		if auth == nil {
+			failed = append(failed, gin.H{"name": name, "error": errAuthFileNotFound.Error()})
+			continue
+		}
+		if auth.Metadata == nil {
+			auth.Metadata = make(map[string]any)
+		}
+		if auth.Attributes == nil {
+			auth.Attributes = make(map[string]string)
+		}
+		if req.Set.Label != nil {
+			label := strings.TrimSpace(*req.Set.Label)
+			auth.Label = label
+			if label == "" {
+				delete(auth.Metadata, "label")
+			} else {
+				auth.Metadata["label"] = label
+			}
+		}
+		if req.Set.Note != nil {
+			note := strings.TrimSpace(*req.Set.Note)
+			if note == "" {
+				delete(auth.Metadata, "note")
+				delete(auth.Attributes, "note")
+			} else {
+				auth.Metadata["note"] = note
+				auth.Attributes["note"] = note
+			}
+		}
+		if req.Set.Group != nil {
+			group := strings.TrimSpace(*req.Set.Group)
+			if group == "" {
+				delete(auth.Metadata, "group")
+				delete(auth.Attributes, "group")
+			} else {
+				auth.Metadata["group"] = group
+				auth.Attributes["group"] = group
+			}
+		}
+		if req.Set.Priority != nil {
+			if *req.Set.Priority == 0 {
+				delete(auth.Metadata, "priority")
+				delete(auth.Attributes, "priority")
+			} else {
+				auth.Metadata["priority"] = *req.Set.Priority
+				auth.Attributes["priority"] = strconv.Itoa(*req.Set.Priority)
+			}
+		}
+		existingTags, _ := metadataStringSlice(auth.Metadata["tags"])
+		nextTags := make([]string, 0, len(existingTags)+len(addTags))
+		for _, tag := range existingTags {
+			if _, remove := removeSet[strings.ToLower(tag)]; !remove {
+				nextTags = append(nextTags, tag)
+			}
+		}
+		nextTags = append(nextTags, addTags...)
+		nextTags = normalizeTags(nextTags)
+		if len(nextTags) == 0 {
+			delete(auth.Metadata, "tags")
+		} else {
+			auth.Metadata["tags"] = nextTags
+		}
+		auth.UpdatedAt = time.Now()
+		if _, errUpdate := h.authManager.Update(c.Request.Context(), auth); errUpdate != nil {
+			failed = append(failed, gin.H{"name": name, "error": errUpdate.Error()})
+			continue
+		}
+		updatedFiles = append(updatedFiles, authDisplayName(auth))
+		PublishManagementEvent("auth.status_changed", h.buildAuthFileEntry(auth))
+	}
+	c.JSON(http.StatusOK, gin.H{
+		"status":  "ok",
+		"updated": len(updatedFiles),
+		"files":   updatedFiles,
+		"failed":  len(failed),
+		"errors":  failed,
+	})
+}
