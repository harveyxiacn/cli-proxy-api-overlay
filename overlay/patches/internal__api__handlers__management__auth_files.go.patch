+// PostDeleteAuthFilesBatch deletes multiple auth files in one request.
+// POST /v0/management/auth-files/delete-batch
+// Body: {"names": ["file1.json", "file2.json"]}
+func (h *Handler) PostDeleteAuthFilesBatch(c *gin.Context) {
+	if h.authManager == nil {
+		c.JSON(http.StatusServiceUnavailable, gin.H{"error": "core auth manager unavailable"})
+		return
+	}
+
+	var req struct {
+		Names []string `json:"names"`
+	}
+	if err := c.ShouldBindJSON(&req); err != nil || len(req.Names) == 0 {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "names is required"})
+		return
+	}
+
+	ctx := c.Request.Context()
+	deletedFiles := make([]string, 0, len(req.Names))
+	failed := make([]gin.H, 0)
+
+	for _, name := range uniqueAuthFileNames(req.Names) {
+		deletedName, _, errDelete := h.deleteAuthFileByName(ctx, name)
+		if errDelete != nil {
+			failed = append(failed, gin.H{"name": name, "error": errDelete.Error()})
+			continue
+		}
+		deletedFiles = append(deletedFiles, deletedName)
+	}
+
+	c.JSON(http.StatusOK, gin.H{
+		"deleted": len(deletedFiles),
+		"files":   deletedFiles,
+		"failed":  len(failed),
+		"errors":  failed,
+	})
+}
