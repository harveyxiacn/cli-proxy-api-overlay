+func (h *Handler) updateAuthFileDisabled(ctx context.Context, name string, disabled bool) (string, error) {
+	name = strings.TrimSpace(name)
+	if name == "" {
+		return "", fmt.Errorf("name is required")
+	}
+	if h == nil || h.authManager == nil {
+		return "", fmt.Errorf("core auth manager unavailable")
+	}
+
+	var targetAuth *coreauth.Auth
+	if auth, ok := h.authManager.GetByID(name); ok {
+		targetAuth = auth
+	} else {
+		auths := h.authManager.List()
+		for _, auth := range auths {
+			if auth.FileName == name {
+				targetAuth = auth
+				break
+			}
+		}
+	}
+
+	if targetAuth == nil {
+		return "", errAuthFileNotFound
+	}
+
+	targetAuth.Disabled = disabled
+	if disabled {
+		targetAuth.Status = coreauth.StatusDisabled
+		targetAuth.StatusMessage = "disabled via management API"
+	} else {
+		targetAuth.Status = coreauth.StatusActive
+		targetAuth.StatusMessage = ""
+	}
+	targetAuth.UpdatedAt = time.Now()
+
+	if _, err := h.authManager.Update(ctx, targetAuth); err != nil {
+		return "", fmt.Errorf("failed to update auth: %w", err)
+	}
+	PublishManagementEvent("auth.status_changed", h.buildAuthFileEntry(targetAuth))
+	if targetAuth.FileName != "" {
+		return targetAuth.FileName, nil
+	}
+	return targetAuth.ID, nil
+}
