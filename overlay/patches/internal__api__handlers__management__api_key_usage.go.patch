+type authStatEntry struct {
+	ID             string                         `json:"id"`
+	Provider       string                         `json:"provider"`
+	Label          string                         `json:"label,omitempty"`
+	Email          string                         `json:"email,omitempty"`
+	Status         string                         `json:"status"`
+	Disabled       bool                           `json:"disabled"`
+	Unavailable    bool                           `json:"unavailable"`
+	Success        int64                          `json:"success"`
+	Failed         int64                          `json:"failed"`
+	RecentRequests []coreauth.RecentRequestBucket `json:"recent_requests"`
+}
+
+// GetAllAuthStats returns usage statistics for every loaded auth, regardless of type.
+// Response shape: {"auths": [...], "total_success": N, "total_failed": N, "count": N}
+func (h *Handler) GetAllAuthStats(c *gin.Context) {
+	if h == nil {
+		c.JSON(http.StatusInternalServerError, gin.H{"error": "handler not initialized"})
+		return
+	}
+
+	h.mu.Lock()
+	manager := h.authManager
+	h.mu.Unlock()
+	if manager == nil {
+		c.JSON(http.StatusServiceUnavailable, gin.H{"error": "core auth manager unavailable"})
+		return
+	}
+
+	now := time.Now()
+	var entries []authStatEntry
+	totalSuccess := int64(0)
+	totalFailed := int64(0)
+
+	for _, auth := range manager.List() {
+		if auth == nil {
+			continue
+		}
+		email := ""
+		if auth.Metadata != nil {
+			if v, ok := auth.Metadata["email"].(string); ok {
+				email = strings.TrimSpace(v)
+			}
+		}
+		if email == "" && auth.Attributes != nil {
+			if v := strings.TrimSpace(auth.Attributes["email"]); v != "" {
+				email = v
+			}
+		}
+		entries = append(entries, authStatEntry{
+			ID:             auth.ID,
+			Provider:       strings.TrimSpace(auth.Provider),
+			Label:          strings.TrimSpace(auth.Label),
+			Email:          email,
+			Status:         string(auth.Status),
+			Disabled:       auth.Disabled,
+			Unavailable:    auth.Unavailable,
+			Success:        auth.Success,
+			Failed:         auth.Failed,
+			RecentRequests: auth.RecentRequestsSnapshot(now),
+		})
+		totalSuccess += auth.Success
+		totalFailed += auth.Failed
+	}
+
+	c.JSON(http.StatusOK, gin.H{
+		"auths":         entries,
+		"total_success": totalSuccess,
+		"total_failed":  totalFailed,
+		"count":         len(entries),
+	})
+}
+
+// PostRefreshAllTokens triggers an immediate background refresh for all non-disabled OAuth credentials.
+func (h *Handler) PostRefreshAllTokens(c *gin.Context) {
+	if h == nil || h.authManager == nil {
+		c.JSON(http.StatusServiceUnavailable, gin.H{"error": "auth manager unavailable"})
+		return
+	}
+	count := h.authManager.TriggerRefreshAll(c.Request.Context())
+	c.JSON(http.StatusOK, gin.H{
+		"status":  "ok",
+		"queued":  count,
+		"message": fmt.Sprintf("Queued %d credential(s) for immediate refresh", count),
+	})
+}
